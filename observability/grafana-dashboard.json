{
  "__comment": "DEMO Grafana dashboard for the Agent Skill Verification metrics. Import via Dashboards > Import and select your Prometheus datasource. Metric names match src/reporting/prometheus-export.ts.",
  "title": "Agent Skill Verification (Demo)",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pass rate",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "skill_pass_rate" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Citation valid rate",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "skill_citation_valid_rate" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Unsupported claim rate (lower is better)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "skill_unsupported_claim_rate" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Tool error rate (lower is better)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "targets": [{ "refId": "A", "expr": "skill_tool_error_rate" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency percentiles (ms, estimated/demo)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "skill_latency_ms_p50", "legendFormat": "p50" },
        { "refId": "B", "expr": "skill_latency_ms_p95", "legendFormat": "p95" },
        { "refId": "C", "expr": "skill_latency_ms_p99", "legendFormat": "p99" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Total runs",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [{ "refId": "A", "expr": "skill_run_total" }]
    }
  ]
}
